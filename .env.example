# Copy this to .env and fill in your key
ANTHROPIC_API_KEY=your-anthropic-key-here

# Optional: Gemini key enables hybrid mode (second answer via Google Search)
# Free tier at https://aistudio.google.com — no credit card needed
# Leave blank to use classic EUR-Lex-only mode
GEMINI_API_KEY=

# Optional overrides
CACHE_DIR=./data/cache

# Maximum number of EUR-Lex laws fetched per search (per year)
# Keep low (3-5) for fast testing; raise to 10+ for deeper research
MAX_LAWS_PER_YEAR=5